# ── CRM / Affiliate API ────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.

# Base URL of your CRM (no trailing slash)
VITE_CRM_HOST=https://your-crm-host.com

# Affiliate API key (from your CRM dashboard)
VITE_CRM_API_KEY=AFF_3_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Source ID to attribute leads (e.g. "website", "fb", "google")
VITE_CRM_SOURCE_ID=website
